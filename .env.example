# EcoSphere ESG Platform — Root Environment Variables
# Copy to .env and adjust if needed.
# These are the defaults used by docker-compose.yml.

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=esg_admin
POSTGRES_PASSWORD=esg_secure_password
POSTGRES_DB=ecosphere_operational
DB_HOST_PORT=5430

# ── Backend ───────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
VITE_API_BASE_URL=/api
