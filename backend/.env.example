# Copy this file to .env and fill in real values.
# .env is gitignored — .env.example is the committed reference.

# ---- App / server -----------------------------------------------------------
APP_NAME=EcoSphere ESG Management Platform
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ---- Database -----------------------------------------------------------------
# Matches the provided docker-compose.yml (ecosphere-db), mapped to host
# port 5433. If the backend itself runs INSIDE the same docker-compose
# network (recommended — see docker-compose.yml), use the service name and
# the container's internal port instead:
#   DATABASE_URL=postgresql://esg_admin:esg_secure_password@ecosphere-db:5432/ecosphere_operational
DATABASE_URL=postgresql://esg_admin:esg_secure_password@localhost:5433/ecosphere_operational

# ---- JWT / Auth -----------------------------------------------------------------
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ---- OAuth: Google (primary provider) -----------------------------------------
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# ---- OAuth: Microsoft (optional) -----------------------------------------------
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common
OAUTH_MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback/microsoft

FRONTEND_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/auth/success

# ---- File uploads ---------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# ---- CORS / Frontend --------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- Scoring engine defaults (fallback/seed values only — real values are
# runtime-configurable via PUT /settings/config and PUT /config/weights) -----
DEFAULT_ENV_WEIGHT=40.0
DEFAULT_SOCIAL_WEIGHT=30.0
DEFAULT_GOVERNANCE_WEIGHT=30.0
DEFAULT_ENVIRONMENTAL_SCORE_BASELINE=50.0
